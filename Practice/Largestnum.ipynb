   "source": [
    "arr = [1,3,5,2,4,6]\n",
    "max = idx = prevMax = 0\n",
    "\n",
    "for ele in arr:\n",
    "    if arr[ele-1] > max:\n",
    "        prevMax = max\n",
    "        max = arr[ele-1]\n",
    "        idx = ele-1\n",
    "\n",
    "print(f\"Maximum value : {max} At index : {idx},  Second max value : {prevMax}\")"
   ]
  }
